{
  "kiroAgent.trustedCommands": [
    "ls",
    "ls *",
    "pwd",
    "cat *",
    "echo *",
    "git status",
    "git log",
    "git log *",
    "git diff",
    "git diff *",
    "git branch",
    "git branch *",
    "npm install",
    "npm install *",
    "npm run *",
    "npm test",
    "make",
    "make *",
    "make proto",
    "uv sync",
    "uv run *",
    "pytest *",
    "python -m *",
    "jj status",
    "jj log",
    "jj log *",
    "jj diff",
    "jj diff *",
    "jj squash *",
    "jj new",
    "jj commit *",
    "jj bookmark *",
    "stow *",
    "brew install *",
    "brew list",
    "grep *",
    "find *",
    "tree",
    "tree *"
  ],
  "kiroAgent.commandDenylist": [
    "rm -rf",
    "sudo",
    "chmod 777",
    "eval",
    "curl | sh",
    "wget | sh",
    "> /dev/",
    "mkfs",
    "dd if=",
    "--force",
    "git push --force",
    "jj abandon"
  ]
}