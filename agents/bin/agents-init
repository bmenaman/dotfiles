#!/bin/bash
# agents-init: install global agent rules into the current repo
# Usage: agents-init [--help]
#
# Run from the root of a repo. Creates:
#   - AGENTS.md symlink in repo root
#   - agents/ directory with symlinks to all rule files

set -e

DOTFILES="${DOTFILES:-$HOME/repos/bmenaman/dotfiles}"

if [ ! -d "$DOTFILES/agents" ]; then
  echo "Error: $DOTFILES/agents not found" >&2
  echo "Set \$DOTFILES to your dotfiles repo path." >&2
  exit 1
fi

if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
  echo "Usage: agents-init"
  echo ""
  echo "Run from the root of a repo to install global agent rules."
  echo "Creates AGENTS.md and agents/ directory with symlinks to $DOTFILES/agents"
  exit 0
fi

# Create AGENTS.md symlink
if [ ! -e "AGENTS.md" ]; then
  ln -s "$DOTFILES/agents/AGENTS.md" AGENTS.md
  echo "Symlinked AGENTS.md → $DOTFILES/agents/AGENTS.md"
elif [ -L "AGENTS.md" ]; then
  echo "AGENTS.md already exists as symlink"
else
  echo "AGENTS.md already exists as regular file"
fi

# Create agents directory and symlink all .md files
mkdir -p agents
for file in "$DOTFILES/agents"/*.md; do
  basename=$(basename "$file")
  if [ "$basename" != "AGENTS.md" ] && [ ! -e "agents/$basename" ]; then
    ln -s "$file" "agents/$basename"
    echo "Symlinked agents/$basename → $file"
  fi
done

echo "Done. Agent rules installed."
